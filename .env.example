# ─── LeeWay Edge RTC — environment variables ─────────────────────────────
# Copy this file to .env and fill in real values for local development.
# For production, set these as GitHub Actions secrets (Settings → Secrets).

# ── Local dev ────────────────────────────────────────────────────────────────
# Not needed if you use the default Vite proxy (ws /dev /health → port 3000).
# No external AI vendors required — LeeWay Edge RTC is fully self-hosted.

# ── TTS (Text-to-Speech) — Browser Web Speech API (zero vendor account) ──────
TTS_ENABLED=true
TTS_PROVIDER=edge
TTS_VOICE=en-US-ChristopherNeural
TTS_RATE=+0%
EDGE_TTS_VOICE=en-US-ChristopherNeural

# ── GitHub Pages build (set as GH Actions secrets) ───────────────────────────
# Base path for the GitHub Pages deployment.
# If your Pages URL is  https://you.github.io/LeeWay-Edge-RTC-main/
# set this to  /LeeWay-Edge-RTC-main/
# If it is the root of a user/org Pages site, leave blank / use /
VITE_BASE_URL="/LeeWay-Edge-RTC-main/"

# The public Fly.io HTTPS URL for the SFU (no trailing slash).
# e.g. https://leeway-sfu.fly.dev
# The frontend derives wss://… from this automatically.
VITE_HTTP_BASE_URL="https://leeway-sfu.fly.dev"

# WebSocket URL for the SFU signaling endpoint.
# Derived from VITE_HTTP_BASE_URL at build time (see deploy-pages.yml).
# Only set this manually if you need to override the auto-derived value.
VITE_SIGNALING_URL="wss://leeway-sfu.fly.dev/ws"

# ── SFU (Fly.io) — set via: fly secrets set KEY=VALUE ────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"

# mediasoup public IP — Fly.io sets FLY_PUBLIC_IP automatically.
# On local dev, set to your LAN IP if ICE fails (e.g. 192.168.1.x)
ANNOUNCED_IP=""
