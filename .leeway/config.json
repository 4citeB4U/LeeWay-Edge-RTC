{
  "version": "1.0.0",
  "project": {
    "name": "leeway-edge-rtc",
    "displayName": "LeeWay Edge RTC Command Center",
    "author": "LeeWay Industries | LeeWay Innovation",
    "creator": "Leonard Lee",
    "license": "PROPRIETARY",
    "organization": "LeeWay Industries",
    "division": "LeeWay Innovation",
    "contact": "leeway-industries"
  },
  "rootDir": "src",
  "agents": {
    "align": { "dryRun": false },
    "audit": { "outputDir": "LeeWay-Standards/reports" },
    "health": { "timeout": 5000 }
  },
  "compliance": {
    "minimumScore": 80,
    "blockOnFail": false
  },
  "policies": {
    "NO_SECRETS_IN_CODE":  { "enforced": true },
    "HEADERS_REQUIRED":    { "enforced": true },
    "TAGS_REQUIRED":       { "enforced": true },
    "NO_CIRCULAR_DEPS":    { "enforced": true },
    "NAMING_CONVENTIONS":  { "enforced": true },
    "PLACEMENT_RULES":     { "enforced": true }
  },
  "identity": {
    "brand": "LeeWay™",
    "fullName": "LEEWAY — Logically Enhanced Engineering Web Architecture Yield",
    "tagline": "Mission-critical RTC at the edge — built by LeeWay Innovation"
  },
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "LeeWay-Standards/node_modules/**",
    "*.min.js"
  ]
}
