# ─── LeeWay Edge RTC – Web Client Environment Variables ──────────────────────
#
# Copy this file to .env.local for local overrides (not committed).
# Set these as GitHub Actions secrets / Fly.io environment when deploying.

# WebSocket URL for the SFU signaling server.
# In dev this is proxied to ws://localhost:3000/ws by Vite automatically.
# In production (GitHub Pages) set this to your Fly.io SFU WebSocket endpoint.
# Example: wss://my-sfu.fly.dev/ws
VITE_SIGNALING_URL=

# HTTP base URL for the SFU API (used to reach /dev/token and other endpoints).
# In dev, Vite proxies /dev → http://localhost:3000 so this can be left empty.
# In production set this to the base URL of your SFU, e.g. https://my-sfu.fly.dev
VITE_HTTP_BASE_URL=

# Base path for the static deployment.
# Set to /LeeWay-Edge-RTC/ when hosting on GitHub Pages under the repo name.
# Leave as / (or empty) for a custom domain or local dev.
VITE_BASE_URL=/
