# ──────────────────────────────────────────────────────────────────────────────
# LeeWay Edge RTC – SFU environment configuration
# Copy this file to services/sfu/.env and fill in your values.
# Never commit the real .env file (it is git-ignored).
# ──────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
HTTP_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_in_production

# ─── mediasoup ────────────────────────────────────────────────────────────────
# Number of mediasoup workers.
# Defaults to the number of logical CPUs when left blank.
MEDIASOUP_NUM_WORKERS=

# UDP/TCP port range for RTP/RTCP (must be open in firewall)
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# IMPORTANT for NATed / cloud deployments:
#   Set ANNOUNCED_IP to the server's public IP address so that
#   ICE candidates advertised to clients are reachable.
#   Example: ANNOUNCED_IP=203.0.113.42
ANNOUNCED_IP=

# ─── TURN ─────────────────────────────────────────────────────────────────────
# Must match the coturn configuration in deploy/coturn/turnserver.conf
TURN_REALM=leeway.local
TURN_SECRET=change_me_turn_secret

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ─── Rate limiting ────────────────────────────────────────────────────────────
WS_MAX_CONNECTIONS_PER_IP=10
WS_MAX_MESSAGE_BYTES=65536
