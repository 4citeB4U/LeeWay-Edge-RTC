[Unit]
Description=coturn TURN server (LeeWay Edge RTC)
After=network.target

[Service]
Type=simple
User=turnserver
Group=turnserver
ExecStart=/usr/bin/turnserver -c /etc/coturn/turnserver.conf
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=coturn

[Install]
WantedBy=multi-user.target
