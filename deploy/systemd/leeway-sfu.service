[Unit]
Description=LeeWay Edge RTC SFU
After=network.target

[Service]
Type=simple
User=leeway
Group=leeway
WorkingDirectory=/opt/leeway/sfu
EnvironmentFile=/etc/leeway/sfu.env
ExecStart=/usr/bin/node /opt/leeway/sfu/dist/index.js
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=leeway-sfu

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/leeway

[Install]
WantedBy=multi-user.target
