# ─── Server ───────────────────────────────────────────────────────────────────
# Port for HTTP (health, metrics) and WebSocket signaling
HTTP_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign/verify JWTs (change in production!)
JWT_SECRET=change_me_in_production

# ─── mediasoup ────────────────────────────────────────────────────────────────
# Number of mediasoup workers (defaults to os.cpus().length)
MEDIASOUP_NUM_WORKERS=

# UDP/TCP port range for RTP/RTCP
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# Announced IP for NATed deployments (set to public IP or domain)
# Leave empty for local/Docker development (0.0.0.0 will be used)
ANNOUNCED_IP=

# ─── TURN ─────────────────────────────────────────────────────────────────────
TURN_REALM=leeway.local
TURN_SECRET=change_me_turn_secret

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Max WebSocket connections per IP
WS_MAX_CONNECTIONS_PER_IP=10
# Max message size in bytes (default 64 KB)
WS_MAX_MESSAGE_BYTES=65536
