{
  "name": "leeway-sfu",
  "version": "1.0.0",
  "description": "LeeWay Edge RTC – mediasoup SFU + signaling service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
